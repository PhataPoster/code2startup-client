
# Copy this file to .env.local and fill in real values.
# Both client and server use the same MongoDB URI.

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=code2startup

# Better Auth — generate a strong secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Optional: Google social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ImgBB image hosting (used in registration / startup logo upload)
NEXT_PUBLIC_IMGBB_KEY=

# Backend Express server (used by client fetch.js)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Stripe (publishable key is safe to expose to the browser)
# Get it from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...