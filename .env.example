# Copy this file to `.env.local` for local development, or set these as
# environment variables on Vercel (Project Settings → Environment Variables).

# Public site URL — used by Better Auth and Stripe redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend Express server base URL — the client calls this for all data.
# On Vercel, point this at your deployed Express server (e.g. on Render/Railway).
NEXT_PUBLIC_SERVER_URL=http://localhost:5000
# Server-only copy used by the /api/proxy route. Same value as above.
BACKEND_URL=http://localhost:5000

# Better Auth — must match the value in the server's .env (and BETTER_AUTH_SECRET
# MUST be identical between client and server, otherwise JWT verification fails).
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-the-same-secret-as-the-server
# Optional — enable Google OAuth by providing both:
# BETTER_AUTH_GOOGLE_CLIENT_ID=
# BETTER_AUTH_GOOGLE_CLIENT_SECRET=

# MongoDB — Better Auth's adapter reads this directly on the server.
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/code2startup